# NextERP environment template
# Copy to `.env.local` for local development. Never commit real secrets.

# --- Public (safe for the browser bundle) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server only ---
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seller identity snapshotted onto invoices at order confirmation
COMPANY_NAME=NextERP Demo Company
COMPANY_EMAIL=billing@example.com
COMPANY_ADDRESS_LINE_1=100 Market Street
COMPANY_ADDRESS_LINE_2=
COMPANY_CITY=San Francisco
COMPANY_REGION=CA
COMPANY_POSTAL_CODE=94105
COMPANY_COUNTRY_CODE=US
